<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="siproc_delivery_logistics.DeliveryMapAction">
        <div class="o_action" style="height:100%; display:flex; flex-direction:column; gap:12px; padding:16px; background:#f5f7fb;">
            <div style="display:flex; justify-content:space-between; gap:12px; flex-wrap:wrap; align-items:center;">
                <div>
                    <div style="font-size:24px; font-weight:700;">Mapa admin de logística</div>
                    <div style="color:#6b7280;">Ruta, puntos y piloto en tiempo real.</div>
                </div>
                <div style="display:flex; gap:8px;">
                    <button class="btn btn-secondary" t-on-click="toggleAutoRefresh"><t t-esc="state.autoRefresh ? 'Auto refresh ON' : 'Auto refresh OFF'"/></button>
                </div>
            </div>
            <div style="display:grid; grid-template-columns:350px 1fr; gap:16px; min-height:650px;">
                <div style="background:white; border-radius:16px; padding:12px; overflow:auto; box-shadow:0 1px 6px rgba(0,0,0,.08);">
                    <div style="font-weight:700; margin-bottom:10px;"><t t-esc="state.route.name || 'Ruta'"/></div>
                    <div style="font-size:13px; color:#6b7280; margin-bottom:10px;">Estado: <t t-esc="state.route.state || '-'"/></div>
                    <div style="font-size:13px; color:#111827; margin-bottom:14px;">Punto actual: <t t-esc="state.route.active_line_name || 'Sin definir'"/></div>
                    <t t-foreach="state.points" t-as="point" t-key="point.id">
                        <div style="border:1px solid #e5e7eb; border-radius:12px; padding:10px; margin-bottom:10px;">
                            <div><strong><t t-esc="point.sequence"/>. <t t-esc="point.name"/></strong></div>
                            <div style="font-size:12px; color:#6b7280;"><t t-esc="point.stop_type"/> · <t t-esc="point.status"/></div>
                            <div style="font-size:12px; color:#374151; margin-top:4px;"><t t-esc="point.address"/></div>
                            <div style="font-size:12px; color:#374151; margin-top:4px;">Tiempo en punto: <t t-esc="point.elapsed_minutes || 0"/> min</div>
                        </div>
                    </t>
                </div>
                <div style="background:white; border-radius:16px; padding:12px; box-shadow:0 1px 6px rgba(0,0,0,.08);">
                    <div t-ref="mapRoot" style="width:100%; min-height:620px; border-radius:12px;"></div>
                </div>
            </div>
        </div>
    </t>
</templates>
