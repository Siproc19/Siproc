<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="delivery_route_map_action" model="ir.actions.client">
        <field name="name">Mapa de ruta</field>
        <field name="tag">siproc_delivery_logistics.delivery_map</field>
    </record>

    <record id="delivery_route_tree" model="ir.ui.view">
        <field name="name">delivery.route.tree</field>
        <field name="model">delivery.route</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="route_type"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="state"/>
                <field name="gps_status"/>
                <field name="total_deliveries"/>
                <field name="delivered_deliveries"/>
            </list>
        </field>
    </record>

    <record id="delivery_route_form" model="ir.ui.view">
        <field name="name">delivery.route.form</field>
        <field name="model">delivery.route</field>
        <field name="arch" type="xml">
            <form string="Ruta de logística">
                <header>
                    <button name="action_plan" string="Planificar" type="object" class="btn-secondary" invisible="state != 'draft'"/>
                    <button name="action_geolocate_all" string="Geolocalizar todo" type="object" class="btn-secondary"/>
                    <button name="action_optimize_sequence" string="Optimizar secuencia" type="object" class="btn-primary"/>
                    <button name="%(delivery_route_map_action)d" string="Mapa admin" type="action" class="btn-secondary"/>
                    <button name="action_open_pilot_panel" string="Panel piloto" type="object" class="btn-secondary"/>
                    <button name="action_start" string="Iniciar ruta" type="object" class="btn-primary" invisible="state not in ('planned','draft')"/>
                    <button name="action_done" string="Cerrar ruta" type="object" class="btn-primary" invisible="state not in ('in_progress','partial')"/>
                    <button name="action_cancel" string="Cancelar" type="object" class="btn-secondary" invisible="state in ('done','cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,planned,in_progress,partial,done,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="route_type"/>
                            <field name="warehouse_id"/>
                            <field name="gps_interval_seconds"/>
                        </group>
                        <group>
                            <field name="vehicle_id"/>
                            <field name="driver_id"/>
                            <field name="active_line_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="GPS en tiempo real">
                        <group>
                            <field name="current_latitude" readonly="1"/>
                            <field name="current_longitude" readonly="1"/>
                            <field name="last_gps_datetime" readonly="1"/>
                        </group>
                        <group>
                            <field name="google_maps_url" widget="url" readonly="1"/>
                            <field name="waze_url" widget="url" readonly="1"/>
                        </group>
                    </group>
                    <group string="Resumen">
                        <field name="total_deliveries" readonly="1"/>
                        <field name="delivered_deliveries" readonly="1"/>
                        <field name="pending_deliveries" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Puntos">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="stop_type"/>
                                    <field name="partner_id"/>
                                    <field name="delivery_address"/>
                                    <field name="location_input" placeholder="Google Maps, Waze o lat,long"/>
                                    <field name="planned_latitude"/>
                                    <field name="planned_longitude"/>
                                    <field name="delivery_status"/>
                                    <field name="elapsed_minutes" readonly="1"/>
                                    <button name="action_copy_partner_address" type="object" string="Copiar dirección"/>
                                    <button name="action_apply_pin" type="object" string="Aplicar pin"/>
                                    <button name="action_geolocate_address" type="object" string="Geolocalizar"/>
                                    <button name="action_set_on_the_way" type="object" string="En camino"/>
                                    <button name="action_mark_delivered" type="object" string="Entregado"/>
                                </list>
                                <form string="Punto de ruta">
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="sequence"/>
                                                <field name="stop_type"/>
                                                <field name="partner_id"/>
                                                <field name="sale_order_id"/>
                                                <field name="picking_id"/>
                                                <field name="delivery_status"/>
                                            </group>
                                            <group>
                                                <field name="receiver_name"/>
                                                <field name="point_started_at" readonly="1"/>
                                                <field name="point_finished_at" readonly="1"/>
                                                <field name="elapsed_minutes" readonly="1"/>
                                            </group>
                                        </group>
                                        <group string="Dirección">
                                            <group>
                                                <field name="delivery_address"/>
                                                <field name="zone"/>
                                                <field name="municipality"/>
                                                <field name="city"/>
                                            </group>
                                            <group>
                                                <field name="state_name"/>
                                                <field name="country_id"/>
                                                <field name="reference"/>
                                            </group>
                                        </group>
                                        <group string="Ubicación planificada">
                                            <group>
                                                <field name="location_input" placeholder="Pega Google Maps, Waze o lat,long"/>
                                                <field name="planned_latitude"/>
                                                <field name="planned_longitude"/>
                                            </group>
                                            <group>
                                                <field name="google_maps_url" widget="url" readonly="1"/>
                                                <field name="waze_url" widget="url" readonly="1"/>
                                            </group>
                                        </group>
                                        <group string="Evidencia y cierre">
                                            <group>
                                                <field name="proof_image" filename="proof_image_filename" widget="image"/>
                                                <field name="proof_image_filename" invisible="1"/>
                                            </group>
                                            <group>
                                                <field name="delivery_notes"/>
                                                <field name="delivered_at" readonly="1"/>
                                                <field name="distance_from_point_km" readonly="1"/>
                                            </group>
                                        </group>
                                        <footer>
                                            <button name="action_copy_partner_address" type="object" string="Copiar dirección" class="btn-secondary"/>
                                            <button name="action_apply_pin" type="object" string="Aplicar pin" class="btn-secondary"/>
                                            <button name="action_geolocate_address" type="object" string="Geolocalizar" class="btn-secondary"/>
                                            <button name="action_open_google_maps" type="object" string="Google Maps" class="btn-secondary"/>
                                            <button name="action_open_waze" type="object" string="Waze" class="btn-secondary"/>
                                            <button name="action_set_on_the_way" type="object" string="En camino" class="btn-secondary"/>
                                            <button name="action_mark_delivered" type="object" string="Marcar entregado" class="btn-primary"/>
                                            <button name="action_mark_rejected" type="object" string="Rechazado"/>
                                            <button name="action_mark_not_found" type="object" string="No localizado"/>
                                            <button name="action_mark_rescheduled" type="object" string="Reprogramado"/>
                                        </footer>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Historial GPS">
                            <field name="gps_log_ids" readonly="1">
                                <list>
                                    <field name="gps_datetime"/>
                                    <field name="vehicle_id"/>
                                    <field name="driver_id"/>
                                    <field name="delivery_line_id"/>
                                    <field name="latitude"/>
                                    <field name="longitude"/>
                                    <field name="speed"/>
                                </list>
                            </field>
                        </page>
                        <page string="Observaciones"><field name="note"/></page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="delivery_route_action" model="ir.actions.act_window">
        <field name="name">Rutas de logística</field>
        <field name="res_model">delivery.route</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
