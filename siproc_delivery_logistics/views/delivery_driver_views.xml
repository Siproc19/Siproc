<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="delivery_driver_view_tree" model="ir.ui.view">
        <field name="name">delivery.driver.tree</field>
        <field name="model">delivery.driver</field>
        <field name="arch" type="xml">
            <list string="Pilotos">
                <field name="name"/>
                <field name="phone"/>
                <field name="license_number"/>
                <field name="vehicle_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="delivery_driver_view_form" model="ir.ui.view">
        <field name="name">delivery.driver.form</field>
        <field name="model">delivery.driver</field>
        <field name="arch" type="xml">
            <form string="Piloto">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="employee_id"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="phone"/>
                            <field name="license_number"/>
                            <field name="vehicle_id"/>
                            <field name="state"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="delivery_driver_action" model="ir.actions.act_window">
        <field name="name">Pilotos</field>
        <field name="res_model">delivery.driver</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
