<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_form_delivery_logistics_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.delivery.logistics.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//div[hasclass('oe_button_box')]" position="inside">
                <button type="object" name="action_view_delivery_routes" class="oe_stat_button" icon="fa-truck">
                    <field name="delivery_route_count" widget="statinfo" string="Rutas"/>
                </button>
            </xpath>

            <xpath expr="//sheet/notebook" position="inside">
                <page string="Logística">
                    <group>
                        <group>
                            <field name="x_delivery_logistics_status" readonly="1"/>
                            <field name="x_delivery_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="x_delivery_vehicle_id" readonly="1"/>
                            <field name="x_delivery_driver_id" readonly="1"/>
                        </group>
                    </group>

                    <field name="delivery_route_line_ids" readonly="1">
                        <list>
                            <field name="route_id"/>
                            <field name="picking_id"/>
                            <field name="partner_id"/>
                            <field name="delivery_status"/>
                            <field name="delivered_at"/>
                            <field name="receiver_name"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
