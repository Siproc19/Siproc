<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_logistics_view" model="ir.ui.view">
        <field name="name">res.config.settings.logistics</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="Logística" string="Logística"
                     data-key="logistics_route_manager">
                    <h2>Logística y Rutas</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="logistics_google_maps_api_key" string="API Key de Google Maps"/>
                                <div class="text-muted">
                                    Necesaria para optimización de rutas y tráfico.
                                    <a href="https://console.cloud.google.com/" target="_blank">Obtener API Key</a>
                                </div>
                                <div class="content-group">
                                    <field name="logistics_google_maps_api_key"
                                        placeholder="AIzaSy..."/>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="logistics_auto_optimize"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="logistics_auto_optimize" string="Optimizar Rutas Automáticamente"/>
                                <div class="text-muted">Optimiza el orden de paradas al confirmar la ruta.</div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="logistics_gps_interval" string="Intervalo GPS (segundos)"/>
                                <div class="text-muted">Frecuencia de actualización GPS del celular del piloto.</div>
                                <div class="content-group">
                                    <field name="logistics_gps_interval"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="logistics_geofence_radius" string="Radio de Llegada (metros)"/>
                                <div class="text-muted">Distancia para detectar llegada automática a una parada.</div>
                                <div class="content-group">
                                    <field name="logistics_geofence_radius"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="logistics_default_nav_app" string="App de Navegación por Defecto"/>
                                <div class="content-group">
                                    <field name="logistics_default_nav_app" widget="radio" options="{'horizontal': true}"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="logistics_notify_manager"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="logistics_notify_manager" string="Notificar al Jefe en cada llegada"/>
                                <div class="text-muted">El jefe recibe notificación cuando el piloto llega a una parada.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
