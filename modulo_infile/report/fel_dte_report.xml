<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- =================================================================== -->
    <!-- HERENCIA DEL REPORTE ESTÁNDAR DE ODOO PARA AGREGAR DATOS FEL       -->
    <!-- =================================================================== -->

    <template id="report_invoice_document_fel_inherit" inherit_id="account.report_invoice_document">
        <xpath expr="//div[@id='informations']" position="before">
            <div class="row mb-3" t-if="o.move_type in ('out_invoice', 'out_refund')">
                <div class="col-12">
                    <div style="background-color:#F5F5F5; border-left:6px solid #F6B500; padding:10px; border-radius:6px;">
                        <t t-if="o.company_id.x_studio_nombre_comercial">
                            <div>
                                <strong style="color:#556B2F;">Nombre Comercial:</strong>
                                <span t-field="o.company_id.x_studio_nombre_comercial"/>
                            </div>
                        </t>
                        <div>
                            <strong style="color:#556B2F;">Régimen:</strong>
                            <span>Sujeto a pagos trimestrales</span>
                        </div>
                    </div>
                </div>
            </div>

            <t t-if="o.move_type in ('out_invoice', 'out_refund') and o.fel_estado">
                <div class="mb-2">
                    <t t-if="o.fel_estado == 'certified'">
                        <span class="badge" style="font-size:12px; background-color:#556B2F; color:white;">✓ DOCUMENTO CERTIFICADO FEL</span>
                    </t>
                    <t t-elif="o.fel_estado == 'cancelled'">
                        <span class="badge" style="font-size:12px; background-color:#dc3545; color:white;">✗ DOCUMENTO ANULADO</span>
                    </t>
                    <t t-elif="o.fel_estado == 'pending'">
                        <span class="badge" style="font-size:12px; background-color:#F6B500; color:black;">⏳ PENDIENTE DE CERTIFICAR</span>
                    </t>
                    <t t-elif="o.fel_estado == 'error'">
                        <span class="badge" style="font-size:12px; background-color:#F18A1A; color:white;">⚠ ERROR EN CERTIFICACIÓN</span>
                    </t>
                </div>

                <t t-if="o.fel_uuid">
                    <div class="row mb-3">
                        <div class="col-12">
                            <div class="p-2 text-center" style="background-color:#F5F5F5; border:2px solid #F18A1A; border-radius:6px;">
                                <strong style="color:#556B2F; font-size:11px;">NÚMERO DE AUTORIZACIÓN FEL (UUID):</strong><br/>
                                <span style="font-family:monospace; font-size:13px; letter-spacing:1px; color:#2c3e50;">
                                    <t t-esc="o.fel_uuid"/>
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-4 text-center">
                            <strong style="font-size:11px; color:#556B2F;">Serie FEL:</strong><br/>
                            <span style="font-size:14px; font-weight:bold;"><t t-esc="o.fel_serie or '-'"/></span>
                        </div>
                        <div class="col-4 text-center">
                            <strong style="font-size:11px; color:#556B2F;">Número FEL:</strong><br/>
                            <span style="font-size:14px; font-weight:bold;"><t t-esc="o.fel_numero or '-'"/></span>
                        </div>
                        <div class="col-4 text-center">
                            <strong style="font-size:11px; color:#556B2F;">Fecha Certificación:</strong><br/>
                            <span style="font-size:12px;">
                                <t t-if="o.fel_fecha_certificacion">
                                    <span t-field="o.fel_fecha_certificacion" t-options='{"widget": "datetime", "format": "dd/MM/yyyy HH:mm"}'/>
                                </t>
                                <t t-else="">-</t>
                            </span>
                        </div>
                    </div>
                </t>
            </t>
        </xpath>

        <xpath expr="//div[@id='total']" position="after">
            <t t-if="o.move_type in ('out_invoice', 'out_refund')">
                <div class="row mt-4">
                    <div class="col-12">
                        <hr style="border-top:1px dashed #ccc;"/>

                        <t t-if="o.fel_estado == 'certified'">
                            <div class="text-center" style="font-size:10px; color:#556B2F;">
                                <p class="mb-1">
                                    <strong>DOCUMENTO TRIBUTARIO ELECTRÓNICO - FEL GUATEMALA</strong><br/>
                                    Certificado por INFILE S.A. - Proveedor autorizado por SAT
                                </p>
                                <p class="mb-0">
                                    Consulte este documento en: <strong>https://report.feel.com.gt/ingfacereloviewer/</strong>
                                </p>
                            </div>
                        </t>

                        <t t-elif="o.fel_estado in ('pending', 'error')">
                            <div class="text-center p-2" style="background-color:#fff3cd; border:1px solid #F6B500; border-radius:4px;">
                                <p class="mb-0" style="color:#856404; font-size:11px;">
                                    <strong>⚠️ DOCUMENTO NO CERTIFICADO</strong><br/>
                                    Este documento aún no tiene validez fiscal. Debe ser certificado ante SAT Guatemala.
                                </p>
                            </div>
                        </t>

                        <t t-elif="o.fel_estado == 'cancelled'">
                            <div class="text-center p-2" style="background-color:#f8d7da; border:1px solid #f5c6cb; border-radius:4px;">
                                <p class="mb-0" style="color:#721c24; font-size:11px;">
                                    <strong>✗ DOCUMENTO ANULADO</strong><br/>
                                    Este documento tributario ha sido anulado ante SAT Guatemala.
                                </p>
                            </div>
                        </t>
                    </div>
                </div>
            </t>
        </xpath>
    </template>

    <!-- =================================================================== -->
    <!-- REPORTE PROPIO DTE FEL                                             -->
    <!-- =================================================================== -->

 <record id="action_report_fel_dte" model="ir.actions.report">
    <field name="name">DTE FEL Guatemala PRUEBA 999</field>
    <field name="model">account.move</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">modulo_infile.report_fel_dte</field>
    <field name="report_file">modulo_infile.report_fel_dte</field>
    <field name="print_report_name">'PRUEBA_999_%s' % (object.name)</field>
    <field name="binding_model_id" ref="account.model_account_move"/>
    <field name="binding_type">report</field>
</record>

    <template id="report_fel_dte">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="modulo_infile.report_fel_dte_document"/>
            </t>
        </t>
    </template>

    <template id="report_fel_dte_document">
        <t t-call="web.external_layout">
            <t t-set="o" t-value="o"/>
            <t t-set="company" t-value="o.company_id"/>
            <t t-set="is_certified" t-value="o.fel_estado == 'certified'"/>
            <t t-set="qr_text" t-value="'UUID:%s|Serie:%s|Numero:%s|Empresa:%s' % (o.fel_uuid or '', o.fel_serie or '', o.fel_numero or '', company.name or '')"/>

            <div class="page">

                <!-- PRUEBA PARA CONFIRMAR QUE ESTE XML SI CARGA -->
                <div style="font-size:24px; color:red; font-weight:bold;">
                    PRUEBA SIPROC 999
                </div>

                <t t-if="not is_certified">
                    <div class="position-absolute" style="top:35%; left:5%; transform:rotate(-30deg); z-index:1000; opacity:0.10;">
                        <h1 style="font-size:90px; color:#556B2F; font-weight:bold;">
                            VISTA PREVIA
                        </h1>
                    </div>
                </t>

                <!-- BANDA SUPERIOR SIPROC -->
                <div class="row mb-3">
                    <div class="col-12">
                        <div style="height:14px; background:linear-gradient(90deg, #F6B500 0%, #F18A1A 55%, #556B2F 100%); border-radius:6px;"></div>
                    </div>
                </div>

                <!-- Encabezado -->
                <div class="row mb-4">
                    <div class="col-7">
                        <div class="company-info p-3" style="background-color:#F5F5F5; border-radius:10px; border-left:6px solid #556B2F;">
                            <div class="row">
                                <div class="col-3">
                                    <img t-if="company.logo"
                                         t-att-src="image_data_uri(company.logo)"
                                         style="max-height:70px; max-width:100%;"/>
                                </div>
                                <div class="col-9">
                                    <h3 class="mb-1" style="color:#556B2F;">
                                        <strong t-field="company.name"/>
                                    </h3>

                                    <t t-if="company.x_studio_nombre_comercial">
                                        <p class="mb-1" style="font-size:12px;">
                                            <strong style="color:#F18A1A;">Nombre Comercial:</strong>
                                            <span t-field="company.x_studio_nombre_comercial"/>
                                        </p>
                                    </t>

                                    <p class="mb-1" style="font-size:12px;">
                                        <strong style="color:#F18A1A;">Régimen:</strong>
                                        <span>Sujeto a pagos trimestrales</span>
                                    </p>

                                    <p class="mb-0" style="font-size:12px;">
                                        <strong>NIT:</strong> <span t-field="company.vat"/><br/>
                                        <strong>Dirección:</strong> <span t-field="company.street"/><br/>
                                        <t t-if="company.city">
                                            <span t-field="company.city"/>,
                                        </t>
                                        <t t-if="company.state_id">
                                            <span t-field="company.state_id.name"/>
                                        </t>
                                        <br/>
                                        <t t-if="company.phone">
                                            <strong>Tel:</strong> <span t-field="company.phone"/><br/>
                                        </t>
                                        <t t-if="company.email">
                                            <strong>Email:</strong> <span t-field="company.email"/>
                                        </t>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-5 text-end">
                        <div class="p-3" style="background:linear-gradient(90deg,#F6B500,#F18A1A); color:white; border-radius:10px;">
                            <h4 class="mb-2" style="color:white;">
                                <strong>
                                    <t t-if="is_certified">DOCUMENTO TRIBUTARIO ELECTRÓNICO</t>
                                    <t t-else="">VISTA PREVIA - DTE</t>
                                </strong>
                            </h4>

                            <table class="table table-sm table-borderless mb-0" style="font-size:12px; color:white;">
                                <tr>
                                    <td class="text-start" style="color:white;"><strong>Tipo:</strong></td>
                                    <td class="text-end" style="color:white;">
                                        <t t-if="o.fel_tipo_documento == 'FACT'">FACTURA</t>
                                        <t t-elif="o.fel_tipo_documento == 'FCAM'">FACTURA CAMBIARIA</t>
                                        <t t-elif="o.fel_tipo_documento == 'FPEQ'">FACTURA PEQUEÑO CONTRIBUYENTE</t>
                                        <t t-elif="o.fel_tipo_documento == 'NCRE'">NOTA DE CRÉDITO</t>
                                        <t t-elif="o.fel_tipo_documento == 'NDEB'">NOTA DE DÉBITO</t>
                                        <t t-else=""><span t-field="o.fel_tipo_documento"/></t>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-start" style="color:white;"><strong>Serie:</strong></td>
                                    <td class="text-end" style="color:white;">
                                        <t t-if="o.fel_serie"><span t-field="o.fel_serie"/></t>
                                        <t t-else=""><span>Pendiente</span></t>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-start" style="color:white;"><strong>Número:</strong></td>
                                    <td class="text-end" style="color:white;">
                                        <t t-if="o.fel_numero"><span t-field="o.fel_numero"/></t>
                                        <t t-else=""><span>Pendiente</span></t>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-start" style="color:white;"><strong>Fecha:</strong></td>
                                    <td class="text-end" style="color:white;">
                                        <span t-field="o.invoice_date"/>
                                    </td>
                                </tr>
                                <tr t-if="o.fel_fecha_certificacion">
                                    <td class="text-start" style="color:white;"><strong>Certificación:</strong></td>
                                    <td class="text-end" style="color:white;">
                                        <span t-field="o.fel_fecha_certificacion" t-options='{"widget": "datetime", "format": "dd/MM/yyyy HH:mm"}'/>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- UUID + QR -->
                <div class="row mb-3">
                    <div class="col-8">
                        <div class="p-3 text-center" style="background-color:#F5F5F5; border:2px solid #F18A1A; border-radius:8px; min-height:120px;">
                            <strong style="color:#556B2F;">NÚMERO DE AUTORIZACIÓN (UUID):</strong><br/>
                            <t t-if="o.fel_uuid">
                                <span style="font-family:monospace; font-size:14px; letter-spacing:1px;" t-field="o.fel_uuid"/>
                                <div class="mt-2">
                                    <strong style="font-size:11px; color:#556B2F;">Serie:</strong>
                                    <span t-esc="o.fel_serie or '-'"/>
                                    &nbsp;&nbsp;|&nbsp;&nbsp;
                                    <strong style="font-size:11px; color:#556B2F;">Número:</strong>
                                    <span t-esc="o.fel_numero or '-'"/>
                                </div>
                            </t>
                            <t t-else="">
                                <div style="padding-top:28px; color:#856404;">
                                    Pendiente de certificación
                                </div>
                            </t>
                        </div>
                    </div>

                    <div class="col-4 text-center">
                        <div class="p-2" style="background-color:#FFFFFF; border:1px solid #dee2e6; border-radius:8px; min-height:140px;">
                            <t t-if="is_certified and o.fel_uuid">
                                <img t-att-src="'/report/barcode/?barcode_type=QR&amp;value=%s&amp;width=180&amp;height=180' % qr_text"
                                     style="width:120px; height:120px;"/>
                                <div style="font-size:10px; color:#556B2F;">
                                    <strong>QR FEL</strong>
                                </div>
                            </t>
                            <t t-else="">
                                <div style="font-size:11px; color:#856404; padding-top:45px;">
                                    QR disponible al certificar
                                </div>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- Receptor -->
                <div class="row mb-4">
                    <div class="col-12">
                        <div class="p-3" style="background-color:#FFFFFF; border:1px solid #dee2e6; border-radius:8px;">
                            <h5 style="color:#556B2F; border-bottom:2px solid #556B2F; padding-bottom:8px;">
                                <strong>DATOS DEL RECEPTOR</strong>
                            </h5>
                            <div class="row">
                                <div class="col-6">
                                    <p class="mb-1" style="font-size:13px;">
                                        <strong>Nombre/Razón Social:</strong><br/>
                                        <span t-field="o.partner_id.name" style="font-size:15px;"/>
                                    </p>
                                </div>
                                <div class="col-6">
                                    <p class="mb-1" style="font-size:13px;">
                                        <strong>NIT:</strong><br/>
                                        <span style="font-size:15px;">
                                            <t t-if="o.partner_id.vat">
                                                <span t-field="o.partner_id.vat"/>
                                            </t>
                                            <t t-else="">CF (Consumidor Final)</t>
                                        </span>
                                    </p>
                                </div>
                            </div>
                            <div class="row mt-2">
                                <div class="col-6">
                                    <p class="mb-0" style="font-size:13px;">
                                        <strong>Dirección:</strong><br/>
                                        <t t-if="o.partner_id.street">
                                            <span t-field="o.partner_id.street"/>
                                        </t>
                                        <t t-else="">Ciudad</t>
                                    </p>
                                </div>
                                <div class="col-6">
                                    <p class="mb-0" style="font-size:13px;">
                                        <strong>Email:</strong><br/>
                                        <t t-if="o.partner_id.email">
                                            <span t-field="o.partner_id.email"/>
                                        </t>
                                        <t t-else="">-</t>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tabla -->
                <div class="row mb-4">
                    <div class="col-12">
                        <table class="table table-sm" style="font-size:12px; border:1px solid #dee2e6;">
                            <thead>
                                <tr style="background:linear-gradient(90deg,#F6B500,#F18A1A); color:white;">
                                    <th class="text-center" style="width:5%;">No.</th>
                                    <th class="text-center" style="width:10%;">Cantidad</th>
                                    <th class="text-center" style="width:8%;">Unidad</th>
                                    <th style="width:42%;">Descripción</th>
                                    <th class="text-end" style="width:12%;">P. Unitario</th>
                                    <th class="text-end" style="width:10%;">Descuento</th>
                                    <th class="text-end" style="width:13%;">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="line_num" t-value="0"/>
                                <t t-foreach="o.invoice_line_ids.filtered(lambda l: l.display_type not in ('line_section', 'line_note') and l.quantity != 0)" t-as="line">
                                    <t t-set="line_num" t-value="line_num + 1"/>
                                    <tr>
                                        <td class="text-center"><t t-esc="line_num"/></td>
                                        <td class="text-center"><span t-field="line.quantity" t-options='{"precision": 2}'/></td>
                                        <td class="text-center">
                                            <t t-if="line.product_uom_id">
                                                <span t-esc="line.product_uom_id.name[:3].upper()"/>
                                            </t>
                                            <t t-else="">UND</t>
                                        </td>
                                        <td><span t-field="line.name"/></td>
                                        <td class="text-end">
                                            <span t-field="line.price_unit" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                        </td>
                                        <td class="text-end">
                                            <t t-if="line.discount">
                                                <span t-field="line.discount"/>%
                                            </t>
                                            <t t-else="">-</t>
                                        </td>
                                        <td class="text-end">
                                            <span t-field="line.price_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Totales -->
                <div class="row mb-4">
                    <div class="col-7">
                        <div class="p-3" style="background-color:#F5F5F5; border-left:6px solid #F6B500; border-radius:6px; font-size:11px;">
                            <strong style="color:#556B2F;">Moneda:</strong> <span t-field="o.currency_id.name"/><br/>
                            <t t-if="o.narration">
                                <strong style="color:#556B2F;">Observaciones:</strong> <span t-field="o.narration"/>
                            </t>
                        </div>
                    </div>
                    <div class="col-5">
                        <table class="table table-sm" style="font-size:13px;">
                            <tr>
                                <td class="text-end"><strong>Subtotal:</strong></td>
                                <td class="text-end" style="width:40%;">
                                    <span t-field="o.amount_untaxed" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                </td>
                            </tr>
                            <tr>
                                <td class="text-end"><strong>IVA (12%):</strong></td>
                                <td class="text-end">
                                    <span t-field="o.amount_tax" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                </td>
                            </tr>
                            <tr style="background-color:#556B2F; color:white;">
                                <td class="text-end"><strong>TOTAL:</strong></td>
                                <td class="text-end">
                                    <strong><span t-field="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></strong>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- Total en letras -->
                <div class="row mb-4">
                    <div class="col-12">
                        <div class="p-3" style="background-color:#F5F5F5; border-left:6px solid #F18A1A; border-radius:6px;">
                            <strong style="color:#556B2F;">Total en Letras:</strong>
                            <span t-esc="o._fel_monto_en_letras()"/>
                        </div>
                    </div>
                </div>

                <!-- Pie -->
                <div class="row mt-4">
                    <div class="col-12 text-center" style="font-size:10px; color:#556B2F;">
                        <hr style="border-top:1px dashed #ccc;"/>

                        <t t-if="is_certified">
                            <p class="mb-1">
                                <strong>DOCUMENTO TRIBUTARIO ELECTRÓNICO - FEL</strong><br/>
                                Certificado por INFILE S.A. - Proveedor autorizado por SAT Guatemala
                            </p>
                            <p class="mb-1" t-if="o.fel_uuid">
                                <strong>UUID:</strong> <span t-field="o.fel_uuid"/><br/>
                                <strong>Fecha de Certificación:</strong>
                                <span t-field="o.fel_fecha_certificacion" t-options='{"widget": "datetime", "format": "dd/MM/yyyy HH:mm:ss"}'/>
                            </p>
                            <p class="mb-0">
                                Documento generado electrónicamente.
                                Consulte en: <strong>https://report.feel.com.gt/ingfacereloviewer/</strong>
                            </p>
                        </t>

                        <t t-else="">
                            <p class="mb-1" style="color:#856404;">
                                <strong>⚠️ VISTA PREVIA - DOCUMENTO NO CERTIFICADO</strong><br/>
                                Este documento aún no ha sido certificado ante SAT Guatemala.
                            </p>
                            <p class="mb-0" style="color:#856404;">
                                Una vez certificado, este documento tendrá validez fiscal.
                            </p>
                        </t>
                    </div>
                </div>

                <!-- Anulado -->
                <t t-if="o.fel_estado == 'cancelled'">
                    <div class="position-absolute" style="top:40%; left:10%; transform:rotate(-30deg); z-index:1000;">
                        <h1 style="font-size:100px; color:rgba(255, 0, 0, 0.3); font-weight:bold;">
                            ANULADO
                        </h1>
                    </div>
                </t>

                <!-- BANDA INFERIOR SIPROC -->
                <div class="row mt-3">
                    <div class="col-12">
                        <div style="height:10px; background:linear-gradient(90deg, #556B2F 0%, #F18A1A 50%, #F6B500 100%); border-radius:6px;"></div>
                    </div>
                </div>

            </div>
        </t>
    </template>

</odoo>
