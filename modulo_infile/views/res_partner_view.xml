<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_fel" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.fel</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='vat']" position="after">
                <field name="cui"/>
            </xpath>

            <xpath expr="//field[@name='vat']" position="after">
                <button name="action_consultar_nit"
                        type="object"
                        string="Consultar NIT"
                        class="btn btn-primary"/>

                <button name="action_consultar_cui"
                        type="object"
                        string="Consultar DPI / CUI"
                        class="btn btn-secondary"/>
            </xpath>

        </field>
    </record>
</odoo>
