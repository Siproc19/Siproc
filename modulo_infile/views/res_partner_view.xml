<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_partner_form_inherit_infile" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.infile</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <field name="infile_resultado" readonly="1"/>
                <button name="action_consultar_nit_infile"
                        string="Consultar NIT INFILE"
                        type="object"/>
            </xpath>
        </field>
    </record>
</odoo>
