        <field name="name">GT Vacation</field>
        <field name="code">GTVAC</field>
        <field name="is_leave">True</field>
    </record>

    <record id="work_entry_type_gt_igss_suspension" model="hr.work.entry.type">
        <field name="name">GT IGSS Suspension</field>
        <field name="code">GTIGSSSUSP</field>
        <field name="is_leave">True</field>
