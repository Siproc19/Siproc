    <record id="work_entry_type_gt_holiday_worked" model="hr.work.entry.type">
        <field name="name">GT Holiday Worked</field>
        <field name="code">GTHOLWRK</field>
        <field name="is_leave">False</field>
    </record>

    <record id="work_entry_type_gt_overtime" model="hr.work.entry.type">
        <field name="name">GT Overtime</field>
        <field name="code">GTOT</field>
        <field name="is_leave">False</field>
    </record>
