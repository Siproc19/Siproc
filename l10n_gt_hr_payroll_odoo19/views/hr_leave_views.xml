<record id="view_leave_type_form_gt_payroll" model="ir.ui.view">
    <field name="name">hr.leave.type.form.gt.payroll</field>
    <field name="model">hr.leave.type</field>
    <field name="inherit_id" ref="hr_holidays.hr_leave_type_view_form_manager"/>
    <field name="arch" type="xml">

        <xpath expr="//sheet/group" position="inside">
            <group string="GT Payroll">
                <field name="is_gt_vacation"/>
                <field name="is_gt_igss_suspension"/>
                <field name="is_gt_paid_license"/>
                <field name="is_gt_unpaid_license"/>
            </group>
        </xpath>

    </field>
</record>
