<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gt_payroll_parameter_tree" model="ir.ui.view">
        <field name="name">gt.payroll.parameter.tree</field>
        <field name="model">gt.payroll.parameter</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="minimum_wage"/>
                <field name="incentive_bonus"/>
                <field name="igss_employee_rate"/>
                <field name="igss_employer_rate"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_gt_payroll_parameter_form" model="ir.ui.view">
        <field name="name">gt.payroll.parameter.form</field>
        <field name="model">gt.payroll.parameter</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="company_id"/>
                            <field name="minimum_wage"/>
                            <field name="incentive_bonus"/>
                            <field name="vacations_days"/>
                        </group>
                    </group>
                    <group string="Cargas y Prestaciones">
                        <group>
                            <field name="igss_employee_rate"/>
                            <field name="igss_employer_rate"/>
                            <field name="irtra_rate"/>
                            <field name="intecap_rate"/>
                        </group>
                        <group>
                            <field name="extra_hour_rate_multiplier"/>
                            <field name="isr_exempt_monthly"/>
                            <field name="isr_rate_low"/>
                            <field name="isr_rate_high"/>
                            <field name="isr_high_threshold"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_gt_payroll_parameter" model="ir.actions.act_window">
        <field name="name">Parámetros GT</field>
        <field name="res_model">gt.payroll.parameter</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
