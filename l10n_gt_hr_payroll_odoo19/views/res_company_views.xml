<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_gt_payroll" model="ir.ui.view">
        <field name="name">res.company.form.gt.payroll</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="GT Payroll">
                    <group>
                        <group>
                            <field name="gt_payroll_enabled"/>
                            <field name="gt_vacation_days_per_year"/>
                            <field name="gt_vacation_count_mode"/>
                            <field name="gt_incentive_bonus_default"/>
                        </group>
                        <group>
                            <field name="gt_payroll_journal_id"/>
                            <field name="gt_liquidation_journal_id"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
