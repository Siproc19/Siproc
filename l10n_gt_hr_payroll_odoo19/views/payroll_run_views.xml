<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_gt_payroll_run_list" model="ir.ui.view">
        <field name="name">gt.payroll.run.list</field>
        <field name="model">gt.payroll.run</field>
        <field name="arch" type="xml">
            <list string="Períodos de planilla">
                <field name="name"/>
                <field name="company_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="total_employees"/>
                <field name="total_net"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_gt_payroll_run_form" model="ir.ui.view">
        <field name="name">gt.payroll.run.form</field>
        <field name="model">gt.payroll.run</field>
        <field name="arch" type="xml">
            <form string="Período de planilla">
                <header>
                    <button name="action_confirm" type="object" string="Confirmar" invisible="state != 'draft'"/>
                    <button name="action_done" type="object" string="Finalizar" invisible="state != 'confirmed'"/>
                    <button name="action_cancel" type="object" string="Cancelar" invisible="state == 'cancel'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done,cancel"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="company_id"/>
                            <field name="parameter_id"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="total_employees" readonly="1"/>
                            <field name="total_net" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Líneas">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="employee_id"/>
                                    <field name="version_id"/>
                                    <field name="worked_days"/>
                                    <field name="extra_hours"/>
                                    <field name="gross_total" readonly="1"/>
                                    <field name="total_deductions" readonly="1"/>
                                    <field name="net_total" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gt_payroll_run" model="ir.actions.act_window">
        <field name="name">Períodos de planilla</field>
        <field name="res_model">gt.payroll.run</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
