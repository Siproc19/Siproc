<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gt_overtime_tree" model="ir.ui.view">
        <field name="name">l10n_gt.overtime.tree</field>
        <field name="model">l10n_gt.overtime</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="version_id"/>
                <field name="date"/>
                <field name="hours"/>
                <field name="rate_multiplier"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_gt_overtime_form" model="ir.ui.view">
        <field name="name">l10n_gt.overtime.form</field>
        <field name="model">l10n_gt.overtime</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state == 'cancel'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,approved,paid,cancel"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="employee_id"/>
                            <field name="version_id"/>
                            <field name="company_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="hours"/>
                            <field name="rate_multiplier"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_gt_overtime" model="ir.actions.act_window">
        <field name="name">GT Overtime</field>
        <field name="res_model">l10n_gt.overtime</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
