<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gt_payroll_parameter_tree" model="ir.ui.view">
        <field name="name">l10n_gt.payroll.parameter.tree</field>
        <field name="model">l10n_gt.payroll.parameter</field>
        <field name="arch" type="xml">
            <tree>
                <field name="company_id"/>
                <field name="code"/>
                <field name="name"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="value_type"/>
                <field name="value_float"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_gt_payroll_parameter_form" model="ir.ui.view">
        <field name="name">l10n_gt.payroll.parameter.form</field>
        <field name="model">l10n_gt.payroll.parameter</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="company_id"/>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="value_type"/>
                            <field name="value_float"/>
                            <field name="value_text"/>
                            <field name="value_bool"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

<record id="action_gt_payroll_parameters" model="ir.actions.act_window">
    <field name="name">Parámetros de planilla GT</field>
    <field name="res_model">l10n_gt.payroll.parameter</field>
    <field name="view_mode">list,form</field>
</record>
</odoo>
