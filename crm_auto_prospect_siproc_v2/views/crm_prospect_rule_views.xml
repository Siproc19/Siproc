<odoo>
    <record id="view_crm_prospect_rule_tree" model="ir.ui.view">
        <field name="name">crm.prospect.rule.tree</field>
        <field name="model">crm.prospect.rule</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="sequence"/>
                <field name="name"/>
                <field name="zone_keyword"/>
                <field name="city_keyword"/>
                <field name="industry_type"/>
                <field name="prospect_type"/>
                <field name="user_id"/>
                <field name="team_id"/>
                <field name="priority"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_crm_prospect_rule_form" model="ir.ui.view">
        <field name="name">crm.prospect.rule.form</field>
        <field name="model">crm.prospect.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                            <field name="sequence"/>
                            <field name="priority"/>
                        </group>
                        <group>
                            <field name="zone_keyword"/>
                            <field name="city_keyword"/>
                            <field name="industry_type"/>
                            <field name="prospect_type"/>
                        </group>
                    </group>
                    <group>
                        <field name="user_id"/>
                        <field name="team_id"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_crm_prospect_rule" model="ir.actions.act_window">
        <field name="name">Reglas de asignación</field>
        <field name="res_model">crm.prospect.rule</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_crm_prospect_rule" name="Reglas de asignación" parent="crm.crm_menu_config" action="action_crm_prospect_rule" sequence="50" groups="sales_team.group_sale_manager"/>
</odoo>
