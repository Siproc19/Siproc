<odoo>
    <record id="crm_lead_view_form_auto_prospect" model="ir.ui.view">
        <field name="name">crm.lead.form.auto.prospect.siproc</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Prospección B2B">
                    <group>
                        <group>
                            <field name="x_company_name"/>
                            <field name="x_contact_name"/>
                            <field name="x_source_name"/>
                            <field name="x_source_url" widget="url"/>
                            <field name="x_capture_date"/>
                            <field name="x_source_batch"/>
                        </group>
                        <group>
                            <field name="x_industry_type"/>
                            <field name="x_prospect_type"/>
                            <field name="x_zone"/>
                            <field name="x_city"/>
                            <field name="x_validation_status"/>
                            <field name="x_data_quality"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="x_lead_score"/>
                            <field name="x_first_contact_deadline"/>
                            <field name="x_last_auto_update"/>
                            <field name="x_followup_alert_sent"/>
                            <field name="x_duplicate_of_id"/>
                        </group>
                        <group>
                            <field name="x_suggested_products"/>
                            <field name="x_import_log"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="crm_lead_view_search_auto_prospect" model="ir.ui.view">
        <field name="name">crm.lead.search.auto.prospect.siproc</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator/>
                <filter string="Prospectos válidos" name="x_valid" domain="[('x_validation_status','=','valid')]"/>
                <filter string="Sin seguimiento" name="x_no_activity" domain="[('activity_ids','=',False)]"/>
                <filter string="Calidad alta" name="x_high_quality" domain="[('x_data_quality','=','high')]"/>
                <filter string="Alertados" name="x_alerted" domain="[('x_followup_alert_sent','=',True)]"/>
                <field name="x_source_name"/>
                <field name="x_industry_type"/>
                <field name="x_zone"/>
                <field name="x_city"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Fuente" name="group_source" context="{'group_by': 'x_source_name'}"/>
                    <filter string="Industria" name="group_industry" context="{'group_by': 'x_industry_type'}"/>
                    <filter string="Zona" name="group_zone" context="{'group_by': 'x_zone'}"/>
                    <filter string="Ciudad" name="group_city" context="{'group_by': 'x_city'}"/>
                    <filter string="Asesor" name="group_user" context="{'group_by': 'user_id'}"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="crm_lead_view_tree_auto_prospect" model="ir.ui.view">
        <field name="name">crm.lead.tree.auto.prospect.siproc</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_oppor"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="inside">
                <field name="x_source_name" optional="show"/>
                <field name="x_industry_type" optional="show"/>
                <field name="x_zone" optional="show"/>
                <field name="x_validation_status" optional="show"/>
                <field name="x_lead_score" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="action_prospect_import_wizard" model="ir.actions.act_window">
        <field name="name">Importar prospectos CSV</field>
        <field name="res_model">prospect.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_crm_prospect_import_wizard" name="Importar prospectos" parent="crm.crm_menu_root" action="action_prospect_import_wizard" sequence="90" groups="sales_team.group_sale_manager"/>
</odoo>
