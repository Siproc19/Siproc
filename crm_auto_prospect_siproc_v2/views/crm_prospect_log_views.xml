<odoo>
    <record id="view_crm_prospect_log_tree" model="ir.ui.view">
        <field name="name">crm.prospect.log.tree</field>
        <field name="model">crm.prospect.log</field>
        <field name="arch" type="xml">
            <tree>
                <field name="create_date"/>
                <field name="lead_id"/>
                <field name="event_type"/>
                <field name="source_name"/>
                <field name="message"/>
            </tree>
        </field>
    </record>

    <record id="view_crm_prospect_log_form" model="ir.ui.view">
        <field name="name">crm.prospect.log.form</field>
        <field name="model">crm.prospect.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="lead_id"/>
                        <field name="event_type"/>
                        <field name="source_name"/>
                        <field name="source_url" widget="url"/>
                        <field name="message"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_crm_prospect_log" model="ir.actions.act_window">
        <field name="name">Bitácora de prospección</field>
        <field name="res_model">crm.prospect.log</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_crm_prospect_log" name="Bitácora prospección" parent="crm.crm_menu_config" action="action_crm_prospect_log" sequence="60" groups="sales_team.group_sale_manager"/>
</odoo>
