<odoo>
    <record id="view_prospect_import_wizard_form" model="ir.ui.view">
        <field name="name">prospect.import.wizard.form</field>
        <field name="model">prospect.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar prospectos">
                <group>
                    <field name="file_name"/>
                    <field name="source_name"/>
                    <field name="file_data" filename="file_name"/>
                    <field name="result_message" readonly="1"/>
                </group>
                <footer>
                    <button name="action_import" string="Importar" type="object" class="btn-primary"/>
                    <button string="Cerrar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
