<odoo>
    <record id="ir_cron_crm_flag_unattended_leads_siproc" model="ir.cron">
        <field name="name">CRM Prospect SIPROC: Alertar leads vencidos</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="state">code</field>
        <field name="code">model.cron_flag_unattended_leads()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_crm_refresh_leads_siproc" model="ir.cron">
        <field name="name">CRM Prospect SIPROC: Recalcular score</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="state">code</field>
        <field name="code">model.cron_refresh_existing_leads()</field>
        <field name="interval_number">6</field>
        <field name="interval_type">hours</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>
</odoo>
