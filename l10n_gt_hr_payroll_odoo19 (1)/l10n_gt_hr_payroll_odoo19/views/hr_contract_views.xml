<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_contract_form_gt_payroll" model="ir.ui.view">
        <field name="name">hr.contract.form.gt.payroll</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Planilla GT">
                    <group>
                        <group>
                            <field name="gt_salary_type"/>
                            <field name="gt_has_incentive_bonus"/>
                            <field name="gt_igss_enabled"/>
                            <field name="gt_isr_enabled"/>
                        </group>
                        <group>
                            <field name="gt_hours_per_day"/>
                            <field name="gt_days_per_month"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
