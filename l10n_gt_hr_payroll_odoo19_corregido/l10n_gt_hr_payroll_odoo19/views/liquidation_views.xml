<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gt_liquidation_list" model="ir.ui.view">
        <field name="name">l10n_gt.liquidation.list</field>
        <field name="model">l10n_gt.liquidation</field>
        <field name="arch" type="xml">
            <list string="Liquidaciones">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="termination_date"/>
                <field name="reason"/>
                <field name="total_liquidation"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_gt_liquidation_form" model="ir.ui.view">
        <field name="name">l10n_gt.liquidation.form</field>
        <field name="model">l10n_gt.liquidation</field>
        <field name="arch" type="xml">
            <form string="Liquidación laboral">
                <header>
                    <button name="action_simulate" type="object" string="Simular" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_hr_validate" type="object" string="Validar RRHH" invisible="state != 'simulated'"/>
                    <button name="action_management_approve" type="object" string="Aprobar Gerencia" invisible="state != 'hr_validated'"/>
                    <button name="action_confirm" type="object" string="Confirmar" class="btn-primary" invisible="state != 'management_approved'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,simulated,hr_validated,management_approved,confirmed,cancel"/>
                </header>
                <sheet>
                    <group>
                        <group string="Información general">
                            <field name="name"/>
                            <field name="employee_id"/>
                            <field name="version_id"/>
                            <field name="company_id" readonly="1"/>
                        </group>
                        <group string="Datos de egreso">
                            <field name="termination_date"/>
                            <field name="reason"/>
                            <field name="payslip_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Cálculo">
                        <group>
                            <field name="pending_salary" readonly="1"/>
                            <field name="pending_vacation" readonly="1"/>
                            <field name="proportional_aguinaldo" readonly="1"/>
                            <field name="proportional_bono14" readonly="1"/>
                        </group>
                        <group>
                            <field name="indemnization" readonly="1"/>
                            <field name="pending_bonus" readonly="1"/>
                            <field name="final_deductions" readonly="1"/>
                            <field name="total_liquidation" readonly="1"/>
                        </group>
                    </group>
                    <group string="Explicación del cálculo">
                        <field name="explanation" readonly="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_gt_liquidations" model="ir.actions.act_window">
        <field name="name">Liquidaciones</field>
        <field name="res_model">l10n_gt.liquidation</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
