<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_version_form_gt_payroll" model="ir.ui.view">
        <field name="name">hr.version.form.gt.payroll</field>
        <field name="model">hr.version</field>
        <field name="inherit_id" ref="hr.hr_contract_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Planilla Guatemala">
                    <group>
                        <group string="Configuración contractual">
                            <field name="gt_contract_type"/>
                            <field name="gt_pay_frequency"/>
                            <field name="gt_salary_daily" readonly="1"/>
                            <field name="gt_seventh_day_policy"/>
                            <field name="gt_analytic_account_id"/>
                        </group>
                        <group string="Aplicaciones">
                            <field name="gt_apply_igss"/>
                            <field name="gt_apply_irtra"/>
                            <field name="gt_apply_intecap"/>
                            <field name="gt_apply_incentive_bonus"/>
                            <field name="gt_apply_overtime"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
