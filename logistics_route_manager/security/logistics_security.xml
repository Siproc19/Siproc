<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════
         GRUPOS DE SEGURIDAD
    ═══════════════════════════════════════════════ -->
    <record id="module_category_logistics" model="ir.module.category">
        <field name="name">Logística</field>
        <field name="description">Gestión de rutas y logística en tiempo real</field>
        <field name="sequence">15</field>
    </record>

    <!-- Jefe de Logística: acceso total -->
    <record id="group_logistics_manager" model="res.groups">
        <field name="name">Jefe de Logística</field>
        <field name="category_id" ref="module_category_logistics"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Acceso completo: crear, editar, eliminar rutas, ver mapa en tiempo real, configurar módulo.</field>
    </record>

    <!-- Coordinador: crear y editar, sin eliminar -->
    <record id="group_logistics_user" model="res.groups">
        <field name="name">Coordinador de Logística</field>
        <field name="category_id" ref="module_category_logistics"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Puede crear y editar rutas y tareas, pero no eliminar ni acceder a configuración.</field>
    </record>

    <!-- Piloto: solo ver sus rutas y actualizar estado -->
    <record id="group_logistics_driver" model="res.groups">
        <field name="name">Piloto Logístico</field>
        <field name="category_id" ref="module_category_logistics"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Solo puede ver sus rutas asignadas y actualizar el estado de las tareas.</field>
    </record>

    <!-- ═══════════════════════════════════════════════
         REGLAS DE REGISTRO (Record Rules)
    ═══════════════════════════════════════════════ -->

    <!-- Piloto solo ve sus propias rutas -->
    <record id="logistics_route_driver_rule" model="ir.rule">
        <field name="name">Piloto: solo sus rutas</field>
        <field name="model_id" ref="logistics_route_manager.model_logistics_route"/>
        <field name="groups" eval="[(4, ref('group_logistics_driver'))]"/>
        <field name="domain_force">[('driver_id.user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Jefe y coordinador ven todas las rutas -->
    <record id="logistics_route_manager_rule" model="ir.rule">
        <field name="name">Jefe/Coordinador: todas las rutas</field>
        <field name="model_id" ref="logistics_route_manager.model_logistics_route"/>
        <field name="groups" eval="[(4, ref('group_logistics_manager')), (4, ref('group_logistics_user'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
