<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="logistics_route_manager.MapWidget">
        <div class="logistics-map-widget">
            <div t-if="state.isLoading" class="logistics-map-loading">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Cargando mapa...</span>
                </div>
                <p style="margin-top:12px; color:#666;">Cargando mapa y tráfico...</p>
            </div>
            <!-- Controles superiores del mapa -->
            <div class="logistics-map-toolbar" t-if="!state.isLoading">
                <button class="btn btn-sm btn-outline-secondary" t-on-click="centerOnDriver">
                    🎯 Centrar en Piloto
                </button>
                <button class="btn btn-sm"
                    t-att-class="state.showTraffic ? 'btn-success' : 'btn-outline-success'"
                    t-on-click="toggleTraffic">
                    🚦 <t t-if="state.showTraffic">Tráfico ON</t><t t-else="">Tráfico OFF</t>
                </button>
                <button class="btn btn-sm" style="background:#05C8F7; color:white; border:none;"
                    t-on-click="openAllInWaze">
                    🚗 Ruta en Waze
                </button>
                <button class="btn btn-sm" style="background:#4285F4; color:white; border:none;"
                    t-on-click="openAllInGoogleMaps">
                    🗺️ Ruta en Google Maps
                </button>
            </div>
            <!-- Contenedor del mapa -->
            <div t-ref="mapContainer" class="logistics-map-canvas"
                style="width:100%; height:420px; border-radius:12px; border:2px solid #dee2e6;">
            </div>
            <!-- Leyenda -->
            <div class="logistics-map-legend" t-if="!state.isLoading">
                <span class="legend-item" style="--color:#6c757d;">⬤ Pendiente</span>
                <span class="legend-item" style="--color:#ffc107;">⬤ En Camino</span>
                <span class="legend-item" style="--color:#fd7e14;">⬤ Llegó</span>
                <span class="legend-item" style="--color:#28a745;">⬤ Completado</span>
                <span class="legend-item" style="--color:#dc3545;">⬤ Fallido</span>
                <span class="legend-item" style="--color:#ff6600;">⬤ Piloto</span>
            </div>
        </div>
    </t>
</templates>
