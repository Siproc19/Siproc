<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════
         VISTA FORMULARIO DE TAREA
    ═══════════════════════════════════════════════ -->
    <record id="logistics_task_form_view" model="ir.ui.view">
        <field name="name">logistics.task.form</field>
        <field name="model">logistics.task</field>
        <field name="arch" type="xml">
            <form string="Tarea Logística">
                <header>
                    <button name="action_mark_arrived" string="📍 Llegué"
                        type="object" class="btn-warning"
                        invisible="state not in ('pending','in_transit')"/>
                    <button name="action_mark_completed" string="✅ Completar"
                        type="object" class="btn-success"
                        invisible="state not in ('arrived','in_transit')"/>
                    <button name="action_navigate_waze" string="🗺️ Navegar con Waze"
                        type="object" class="btn-info"/>
                    <button name="action_navigate_google_maps" string="🗺️ Google Maps"
                        type="object" class="btn-primary"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="pending,in_transit,arrived,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label class="o_label_optional" for="task_type"/>
                        <field name="task_type" widget="radio" options="{'horizontal': true}"/>
                        <h1><field name="name" placeholder="Descripción de la tarea..."/></h1>
                    </div>
                    <group>
                        <group string="📍 Ubicación">
                            <field name="location_id" options="{'no_create': True}"/>
                            <field name="address"/>
                            <field name="latitude"/>
                            <field name="longitude"/>
                        </group>
                        <group string="👤 Contacto">
                            <field name="contact_name"/>
                            <field name="contact_phone" widget="phone"/>
                            <field name="priority" widget="priority"/>
                            <field name="estimated_arrival"/>
                        </group>
                    </group>
                    <!-- Botones de navegación grandes (estilo móvil) -->
                    <div class="logistics_nav_buttons" style="display:flex; gap:12px; padding:16px 0; flex-wrap:wrap;">
                        <button class="btn btn-lg logistics-waze-btn"
                            style="background:linear-gradient(135deg,#05C8F7,#0099CC);color:white;border:none;border-radius:12px;padding:14px 24px;font-size:16px;font-weight:700;flex:1;min-width:160px;"
                            onclick="window.open('waze://?ll=' + document.querySelector('[name=latitude] input').value + ',' + document.querySelector('[name=longitude] input').value + '&amp;navigate=yes', '_blank')">
                            🚗 Navegar con Waze
                        </button>
                        <button class="btn btn-lg logistics-gmaps-btn"
                            style="background:linear-gradient(135deg,#4285F4,#1A56CC);color:white;border:none;border-radius:12px;padding:14px 24px;font-size:16px;font-weight:700;flex:1;min-width:160px;"
                            onclick="window.open('https://www.google.com/maps/dir/?api=1&amp;destination=' + document.querySelector('[name=latitude] input').value + ',' + document.querySelector('[name=longitude] input').value + '&amp;travelmode=driving&amp;dir_action=navigate', '_blank')">
                            🗺️ Navegar con Google Maps
                        </button>
                    </div>
                    <notebook>
                        <!-- Campos por tipo de tarea -->
                        <page string="📦 Entrega" name="delivery"
                            invisible="task_type != 'delivery'">
                            <group>
                                <field name="stock_picking_id"/>
                                <field name="delivery_products" widget="text"/>
                                <field name="delivery_weight_kg"/>
                            </group>
                        </page>
                        <page string="🛒 Compra" name="purchase"
                            invisible="task_type != 'purchase'">
                            <group>
                                <group>
                                    <field name="purchase_order_id"/>
                                    <field name="authorized_amount" string="Monto Autorizado (Q)"/>
                                    <field name="spent_amount" string="Monto Gastado (Q)"/>
                                </group>
                                <group>
                                    <field name="shopping_list" widget="text" string="Lista de Compras"/>
                                    <field name="invoice_photo" widget="image" string="Foto Factura"/>
                                </group>
                            </group>
                        </page>
                        <page string="📋 Mandado" name="errand"
                            invisible="task_type != 'errand'">
                            <group>
                                <field name="errand_description" widget="text"/>
                                <field name="requested_by"/>
                                <field name="errand_amount" string="Monto para Gastos (Q)"/>
                            </group>
                        </page>
                        <page string="🏦 Banco" name="bank"
                            invisible="task_type != 'bank'">
                            <group>
                                <group>
                                    <field name="bank_name"/>
                                    <field name="bank_transaction_type"/>
                                    <field name="bank_amount" string="Monto (Q)"/>
                                    <field name="account_number"/>
                                </group>
                                <group>
                                    <field name="bank_voucher" widget="image" string="Comprobante"/>
                                </group>
                            </group>
                        </page>
                        <page string="📸 Evidencias" name="evidence">
                            <group>
                                <group>
                                    <field name="evidence_photo_1" widget="image" string="Foto 1"/>
                                    <field name="evidence_photo_2" widget="image" string="Foto 2"/>
                                    <field name="evidence_photo_3" widget="image" string="Foto 3"/>
                                </group>
                                <group>
                                    <field name="signature" widget="image" string="Firma Digital"/>
                                    <field name="signature_name" string="Nombre del Firmante"/>
                                </group>
                            </group>
                        </page>
                        <page string="📝 Notas" name="notes">
                            <field name="notes" placeholder="Instrucciones especiales, indicaciones de acceso, etc."/>
                            <group invisible="state != 'failed'">
                                <field name="failure_reason" string="Razón de Fallo"/>
                            </group>
                            <group>
                                <field name="actual_arrival" readonly="1"/>
                                <field name="actual_departure" readonly="1"/>
                                <field name="time_at_location" readonly="1" string="Tiempo en Lugar (min)"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════
         VISTA LISTA DE TAREAS
    ═══════════════════════════════════════════════ -->
    <record id="logistics_task_list_view" model="ir.ui.view">
        <field name="name">logistics.task.list</field>
        <field name="model">logistics.task</field>
        <field name="arch" type="xml">
            <list string="Tareas Logísticas"
                decoration-success="state == 'completed'"
                decoration-danger="state == 'failed'"
                decoration-warning="state == 'arrived'"
                decoration-info="state == 'in_transit'">
                <field name="sequence" widget="handle"/>
                <field name="route_id"/>
                <field name="task_type" widget="badge"/>
                <field name="name"/>
                <field name="address"/>
                <field name="contact_name"/>
                <field name="priority" widget="priority"/>
                <field name="estimated_arrival"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'completed'"
                    decoration-danger="state == 'failed'"
                    decoration-warning="state == 'arrived'"
                    decoration-info="state == 'in_transit'"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════
         VISTA KANBAN DE TAREAS
    ═══════════════════════════════════════════════ -->
    <record id="logistics_task_kanban_view" model="ir.ui.view">
        <field name="name">logistics.task.kanban</field>
        <field name="model">logistics.task</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="name"/>
                <field name="task_type"/>
                <field name="state"/>
                <field name="address"/>
                <field name="contact_name"/>
                <field name="priority"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_card_header">
                                <span class="badge bg-info">
                                    <field name="task_type"/>
                                </span>
                                <field name="priority" widget="priority" class="float-end"/>
                            </div>
                            <div class="o_kanban_card_content">
                                <strong><field name="name"/></strong>
                                <div class="text-muted small mt-1">
                                    📍 <field name="address"/>
                                </div>
                                <div class="small mt-1">
                                    👤 <field name="contact_name"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Búsqueda tareas -->
    <record id="logistics_task_search_view" model="ir.ui.view">
        <field name="name">logistics.task.search</field>
        <field name="model">logistics.task</field>
        <field name="arch" type="xml">
            <search string="Buscar Tareas">
                <field name="name"/>
                <field name="route_id"/>
                <field name="address"/>
                <filter name="delivery" string="Entregas" domain="[('task_type','=','delivery')]"/>
                <filter name="purchase" string="Compras" domain="[('task_type','=','purchase')]"/>
                <filter name="errand" string="Mandados" domain="[('task_type','=','errand')]"/>
                <filter name="bank" string="Bancos" domain="[('task_type','=','bank')]"/>
                <separator/>
                <filter name="pending" string="Pendientes" domain="[('state','=','pending')]"/>
                <filter name="in_transit" string="En Camino" domain="[('state','=','in_transit')]"/>
                <filter name="completed" string="Completadas" domain="[('state','=','completed')]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_type" string="Tipo" context="{'group_by':'task_type'}"/>
                    <filter name="group_route" string="Ruta" context="{'group_by':'route_id'}"/>
                    <filter name="group_state" string="Estado" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Acción de tareas -->
    <record id="action_logistics_tasks" model="ir.actions.act_window">
        <field name="name">Tareas Logísticas</field>
        <field name="res_model">logistics.task</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No hay tareas aún</p>
            <p>Las tareas se crean dentro de cada ruta logística.</p>
        </field>
    </record>
</odoo>
