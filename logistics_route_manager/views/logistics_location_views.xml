<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════
         UBICACIONES / LUGARES FRECUENTES
    ═══════════════════════════════════════════════ -->
    <record id="logistics_location_form_view" model="ir.ui.view">
        <field name="name">logistics.location.form</field>
        <field name="model">logistics.location</field>
        <field name="arch" type="xml">
            <form string="Ubicación Logística">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="action" class="oe_stat_button" icon="fa-tasks"
                            name="%(action_logistics_tasks)d"
                            context="{'default_location_id': id}">
                            <field name="task_count" widget="statinfo" string="Tareas"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre del lugar..."/>
                        </h1>
                    </div>

                    <group>
                        <group string="Información">
                            <field name="location_type"/>
                            <field name="address"/>
                            <field name="contact_name"/>
                            <field name="contact_phone" widget="phone"/>
                            <field name="active"/>
                        </group>

                        <group string="Coordenadas GPS">
                            <field name="latitude"/>
                            <field name="longitude"/>
                        </group>
                    </group>

                    <group string="Notas e Indicaciones">
                        <field name="notes" nolabel="1"
                            placeholder="Indicaciones de acceso, referencias, horarios de atención..."/>
                    </group>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <record id="logistics_location_list_view" model="ir.ui.view">
        <field name="name">logistics.location.list</field>
        <field name="model">logistics.location</field>
        <field name="arch" type="xml">
            <list string="Ubicaciones">
                <field name="name"/>
                <field name="location_type" widget="badge"/>
                <field name="address"/>
                <field name="contact_name"/>
                <field name="contact_phone" widget="phone"/>
                <field name="task_count" string="Tareas"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="logistics_location_search_view" model="ir.ui.view">
        <field name="name">logistics.location.search</field>
        <field name="model">logistics.location</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="address"/>
                <field name="location_type"/>

                <filter name="customer" string="Clientes" domain="[('location_type', '=', 'customer')]"/>
                <filter name="supplier" string="Proveedores" domain="[('location_type', '=', 'supplier')]"/>
                <filter name="bank" string="Bancos" domain="[('location_type', '=', 'bank')]"/>
                <filter name="office" string="Oficinas" domain="[('location_type', '=', 'office')]"/>
                <filter name="active_filter" string="Activos" domain="[('active', '=', True)]"/>

                <separator/>

                <filter name="group_type" string="Tipo" context="{'group_by': 'location_type'}"/>
            </search>
        </field>
    </record>

    <record id="action_logistics_locations" model="ir.actions.act_window">
        <field name="name">Lugares Frecuentes</field>
        <field name="res_model">logistics.location</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
