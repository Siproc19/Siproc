<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════
         PILOTOS
    ═══════════════════════════════════════════════ -->
    <record id="logistics_driver_form_view" model="ir.ui.view">
        <field name="name">logistics.driver.form</field>
        <field name="model">logistics.driver</field>
        <field name="arch" type="xml">
            <form string="Piloto Logístico">
                <sheet>
                    <field name="image" widget="image"
                        style="width:96px; height:96px; border-radius:50%; float:right; margin:-16px 0 0 16px;"/>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <div>
                            <span invisible="not is_online"
                                class="badge bg-success">🟢 En Línea</span>
                            <span invisible="is_online"
                                class="badge bg-secondary">⚫ Desconectado</span>
                        </div>
                    </div>
                    <group>
                        <group string="Información del Piloto">
                            <field name="employee_id" options="{'no_create': True}"/>
                            <field name="user_id" options="{'no_create': True}"/>
                            <field name="phone" widget="phone"/>
                            <field name="is_active"/>
                        </group>
                        <group string="Licencia de Conducción">
                            <field name="license_number"/>
                            <field name="license_type"/>
                            <field name="license_expiry"
                                decoration-danger="license_expiry and license_expiry &lt; current_date"/>
                        </group>
                    </group>
                    <group>
                        <group string="App de Navegación">
                            <field name="preferred_nav_app" widget="radio" options="{'horizontal': true}"/>
                        </group>
                        <group string="Posición GPS Actual" invisible="not current_latitude">
                            <field name="current_latitude" readonly="1"/>
                            <field name="current_longitude" readonly="1"/>
                            <field name="current_speed" readonly="1" string="Velocidad (km/h)"/>
                            <field name="last_gps_update" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Ruta Actual" name="current_route">
                            <field name="current_route_id" readonly="1"/>
                        </page>
                        <page string="Historial de Rutas" name="routes">
                            <field name="route_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="total_tasks"/>
                                    <field name="completed_tasks"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="logistics_driver_list_view" model="ir.ui.view">
        <field name="name">logistics.driver.list</field>
        <field name="model">logistics.driver</field>
        <field name="arch" type="xml">
            <list string="Pilotos"
                decoration-success="is_online"
                decoration-muted="not is_active">
                <field name="employee_id"/>
                <field name="phone"/>
                <field name="license_number"/>
                <field name="license_expiry"
                    decoration-danger="license_expiry and license_expiry &lt; current_date"/>
                <field name="preferred_nav_app"/>
                <field name="current_route_id" readonly="1"/>
                <field name="is_online" widget="boolean_toggle" readonly="1"/>
                <field name="current_speed" string="Vel. km/h" readonly="1"/>
                <field name="last_gps_update" readonly="1" string="Último GPS"/>
                <field name="is_active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="action_logistics_drivers" model="ir.actions.act_window">
        <field name="name">Pilotos</field>
        <field name="res_model">logistics.driver</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ═══════════════════════════════════════════════
         VEHÍCULOS
    ═══════════════════════════════════════════════ -->
    <record id="logistics_vehicle_form_view" model="ir.ui.view">
        <field name="name">logistics.vehicle.form</field>
        <field name="model">logistics.vehicle</field>
        <field name="arch" type="xml">
            <form string="Vehículo">
                <sheet>
                    <field name="image" widget="image"
                        style="width:120px; height:90px; float:right; object-fit:cover; border-radius:8px;"/>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                        <h2><field name="plate" placeholder="Placa..."/></h2>
                    </div>
                    <group>
                        <group>
                            <field name="vehicle_type"/>
                            <field name="brand"/>
                            <field name="model"/>
                            <field name="year"/>
                            <field name="color"/>
                        </group>
                        <group>
                            <field name="capacity_kg"/>
                            <field name="fuel_type"/>
                            <field name="is_available" readonly="1"/>
                            <field name="current_driver_id" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Observaciones del vehículo..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="logistics_vehicle_list_view" model="ir.ui.view">
        <field name="name">logistics.vehicle.list</field>
        <field name="model">logistics.vehicle</field>
        <field name="arch" type="xml">
            <list string="Vehículos"
                decoration-success="is_available"
                decoration-warning="not is_available">
                <field name="name"/>
                <field name="plate"/>
                <field name="vehicle_type"/>
                <field name="brand"/>
                <field name="model"/>
                <field name="capacity_kg" string="Capacidad kg"/>
                <field name="current_driver_id" readonly="1" string="Piloto Actual"/>
                <field name="is_available" readonly="1" string="Disponible"/>
            </list>
        </field>
    </record>

    <record id="action_logistics_vehicles" model="ir.actions.act_window">
        <field name="name">Vehículos</field>
        <field name="res_model">logistics.vehicle</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
