<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_logistics_view" model="ir.ui.view">
        <field name="name">res.config.settings.logistics</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Logística" name="logistics_route_manager" data-key="logistics_route_manager">
                    <block title="Logística y Rutas" name="logistics_settings_block">

                        <setting string="API Key de Google Maps"
                                 help="Necesaria para optimización de rutas y tráfico.">
                            <field name="logistics_google_maps_api_key"
                                   placeholder="AIzaSy..."/>
                        </setting>

                        <setting string="Optimizar Rutas Automáticamente"
                                 help="Optimiza el orden de paradas al confirmar la ruta.">
                            <field name="logistics_auto_optimize"/>
                        </setting>

                        <setting string="Intervalo GPS (segundos)"
                                 help="Frecuencia de actualización GPS del celular del piloto.">
                            <field name="logistics_gps_interval"/>
                        </setting>

                        <setting string="Radio de Llegada (metros)"
                                 help="Distancia para detectar llegada automática a una parada.">
                            <field name="logistics_geofence_radius"/>
                        </setting>

                        <setting string="App de Navegación por Defecto"
                                 help="Selecciona la aplicación de navegación predeterminada.">
                            <field name="logistics_default_nav_app" widget="radio"
                                   options="{'horizontal': true}"/>
                        </setting>

                        <setting string="Notificar al Jefe en cada llegada"
                                 help="El jefe recibe notificación cuando el piloto llega a una parada.">
                            <field name="logistics_notify_manager"/>
                        </setting>

                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
