<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Secuencia para numeración de rutas -->
    <record id="logistics_route_sequence" model="ir.sequence">
        <field name="name">Secuencia de Rutas Logísticas</field>
        <field name="code">logistics.route</field>
        <field name="prefix">RUTA-%(year)s-</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Tipos de ubicaciones frecuentes de ejemplo -->
    <record id="logistics_location_office" model="logistics.location">
        <field name="name">Oficina Central</field>
        <field name="location_type">office</field>
        <field name="address">Ciudad de Guatemala, Guatemala</field>
        <field name="latitude">14.6349</field>
        <field name="longitude">-90.5069</field>
        <field name="color">1</field>
    </record>
</odoo>
