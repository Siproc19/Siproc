<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_gt_liquidation_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Liquidación Laboral - Guatemala</h2>
                        <p><strong>Documento:</strong> <span t-esc="o.name"/></p>
                        <p><strong>Empleado:</strong> <span t-esc="o.employee_id.name"/></p>
                        <p><strong>Contrato:</strong> <span t-esc="o.contract_id.name"/></p>
                        <p><strong>Fecha de egreso:</strong> <span t-esc="o.termination_date"/></p>
                        <p><strong>Motivo:</strong> <span t-esc="o.reason"/></p>

                        <table class="table table-sm table-bordered mt-3">
                            <thead>
                                <tr>
                                    <th>Concepto</th>
                                    <th class="text-end">Monto</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr><td>Salario pendiente</td><td class="text-end"><span t-esc="'%.2f' % o.pending_salary"/></td></tr>
                                <tr><td>Vacaciones pendientes</td><td class="text-end"><span t-esc="'%.2f' % o.pending_vacation"/></td></tr>
                                <tr><td>Aguinaldo proporcional</td><td class="text-end"><span t-esc="'%.2f' % o.proportional_aguinaldo"/></td></tr>
                                <tr><td>Bono 14 proporcional</td><td class="text-end"><span t-esc="'%.2f' % o.proportional_bono14"/></td></tr>
                                <tr><td>Indemnización</td><td class="text-end"><span t-esc="'%.2f' % o.indemnization"/></td></tr>
                                <tr><td>Bonificación pendiente</td><td class="text-end"><span t-esc="'%.2f' % o.pending_bonus"/></td></tr>
                                <tr><td>Descuentos finales</td><td class="text-end"><span t-esc="'%.2f' % o.final_deductions"/></td></tr>
                                <tr>
                                    <td><strong>Total liquidación</strong></td>
                                    <td class="text-end"><strong><span t-esc="'%.2f' % o.total_liquidation"/></strong></td>
                                </tr>
                            </tbody>
                        </table>

                        <p class="mt-3"><strong>Explicación:</strong></p>
                        <p><span t-esc="o.explanation or ''"/></p>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
