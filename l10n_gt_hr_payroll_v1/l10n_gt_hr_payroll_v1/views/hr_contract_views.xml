<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_contract_form_gt_payroll" model="ir.ui.view">
        <field name="name">hr.contract.form.gt.payroll</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="GT Payroll">
                    <group>
                        <group string="Contract Settings">
                            <field name="gt_contract_type"/>
                            <field name="gt_pay_frequency"/>
                            <field name="gt_salary_daily" readonly="1"/>
                            <field name="gt_seventh_day_policy"/>
                            <field name="gt_analytic_account_id"/>
                        </group>
                        <group string="Flags">
                            <field name="gt_apply_igss"/>
                            <field name="gt_apply_irtra"/>
                            <field name="gt_apply_intecap"/>
                            <field name="gt_apply_incentive_bonus"/>
                            <field name="gt_apply_overtime"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
