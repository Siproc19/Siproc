<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_payslip_form_gt_payroll" model="ir.ui.view">
        <field name="name">hr.payslip.form.gt.payroll</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group" position="inside">
                <group string="GT Payroll">
                    <field name="gt_payroll_type"/>
                    <field name="gt_liquidation_id" readonly="1"/>
                </group>
            </xpath>
            <xpath expr="//sheet/notebook" position="inside">
                <page string="GT Explanation">
                    <group>
                        <field name="gt_explain_json" nolabel="1" widget="text" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="action_refresh_gt_explanation_server" model="ir.actions.server">
        <field name="name">Refresh GT Explanation</field>
        <field name="model_id" ref="hr_payroll.model_hr_payslip"/>
        <field name="binding_model_id" ref="hr_payroll.model_hr_payslip"/>
        <field name="state">code</field>
        <field name="code">records.action_refresh_gt_explanation()</field>
    </record>
</odoo>
